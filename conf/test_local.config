/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running local tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a fast and simple pipeline test locally.
*/

params {
    config_profile_name        = 'Test local profile'
    config_profile_description = 'Minimal test dataset to check pipeline function locally'

    // Limit resources so that this can run locally smoothly
    max_cpus   = 4
    max_memory = '8.GB'
    max_time   = '6.h'

    // Input data
    input   = '/Users/siyangming/nextflow_nf_core/circdna.nf/testdatasets/samplesheet/samplesheet_local.csv'
    input_format   = 'FASTQ'

    // Genome references
    fasta               = '/Users/siyangming/nextflow_nf_core/circdna.nf/testdatasets/reference/genome.fa'
    circle_identifier   = 'circexplorer2,circle_finder,circle_map_realign,circle_map_repeats,unicycler'
    igenomes_ignore     = true

    // Extra references (if used by specific modules like AmpliconArchitect)
    cnvkit_cnn          = '/Users/siyangming/nextflow_nf_core/circdna.nf/testdatasets/cnvkit/dummy_file.cnn'
    mosek_license_dir   = '/Users/siyangming/nextflow_nf_core/circdna.nf/testdatasets/mosek/'

    // Needed input
    skip_markduplicates = false

    reference_build     = "GRCh38"
}

// Override process resource limits for local execution specifically
process {
    withLabel:process_low {
        cpus   = { 2     * task.attempt }
        memory = { 4.GB * task.attempt }
    }
    withLabel:process_medium {
        cpus   = { 4     * task.attempt }
        memory = { 8.GB * task.attempt }
    }
    withLabel:process_high {
        cpus   = { 4    * task.attempt }
        memory = { 8.GB * task.attempt }
    }

    // Force single-thread for Circle-Map Realign on small test datasets.
    // Multi-process cluster splitting in Circle-Map raises
    //   "An error happenend during execution. Exiting"
    // when candidate cluster count < threads (typical for tiny test BAMs).
    // Production / large samples should NOT need this override.
    withName: 'CIRCLEMAP_REALIGN' {
        cpus = 1
    }

    // Override TRIMGALORE resources for local testing
    // Default process_medium requires 36GB, which exceeds typical local machine memory
    withName: 'TRIMGALORE' {
        cpus   = 2
        memory = 4.GB
        time   = 2.h
    }

    withName: 'UNICYCLER' {
        ext.args = "--no_rotate --kmers 27 --spades_options '-m 8192'"
    }
}

// Local testing conventions
workDir = './nextflow_work'
//resume  = true

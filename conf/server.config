params {
    max_memory = '256 GB'
    max_cpus = 64
    max_time = '72.h'

    config_profile_name = 'Server profile'
    config_profile_description = 'Production configuration for server with 128 CPUs and 503GB memory'

    fasta_base_path = "/data1/users/siyangming/FASTA"

    input_format = 'FASTQ'
    //circle_identifier = 'circexplorer2,circle_finder,circle_map_realign,circle_map_repeats,unicycler'
    circle_identifier = 'circexplorer2,circle_finder,circle_map_realign,circle_map_repeats'

    skip_markduplicates = false

    genomes {
        Arabidopsis_thaliana {
            fasta = "${params.fasta_base_path}/Arabidopsis_thaliana.TAIR10.dna.fa.gz"
        }
        Oryza_sativa {
            fasta = "${params.fasta_base_path}/Oryza_sativa.IRGSP-1.0.dna.fa.gz"
        }
        Triticum_aestivum {
            fasta = "${params.fasta_base_path}/Triticum_aestivum.IWGSC.dna.fa.gz"
        }
        Solanum_lycopersicum {
            fasta = "${params.fasta_base_path}/Solanum_lycopersicum_gca000188115v5cm.SL4.0.dna.fa.gz"
        }
        Daucus_carota {
            fasta = "${params.fasta_base_path}/Daucus_carota.ASM162521v1.dna.fa.gz"
        }
        Helianthus_annuus {
            fasta = "${params.fasta_base_path}/Helianthus_annuus.HanXRQr2.0-SUNRISE.dna.fa.gz"
        }
        Alopecurus_myosuroides {
            fasta = "${params.fasta_base_path}/Alopecurus_myosuroides_v1.fa.gz"
        }
        Amaranthus_palmeri_hap1 {
            fasta = "${params.fasta_base_path}/Amaranthus_palmeri_hap1_v01.fa.gz"
        }
        Amaranthus_palmeri_hap2 {
            fasta = "${params.fasta_base_path}/Amaranthus_palmeri_hap2_v01.fa.gz"
        }
        Artemisia_annua {
            fasta = "${params.fasta_base_path}/Artemisia_annua_v1.fa.gz"
        }
        Cryptomeria_japonica {
            fasta = "${params.fasta_base_path}/Cryptomeria_japonica_1.0.fa.gz"
        }
        Nicotiana_benthamiana {
            fasta = "${params.fasta_base_path}/Nicotiana_benthamiana_v1.fa.gz"
        }
        Tragopogon_porrifolius_hap1 {
            fasta = "${params.fasta_base_path}/Tragopogon_porrifolius_hap1.1.fa.gz"
        }
        Tragopogon_porrifolius_hap2 {
            fasta = "${params.fasta_base_path}/Tragopogon_porrifolius_hap2.1.fa.gz"
        }
        Beta_vulgaris {
            fasta = "${params.fasta_base_path}/Beta_vulgaris.RefBeet-1.2.2.dna.fa.gz"
        }
        Lycium_ruthenicum {
            fasta = "${params.fasta_base_path}/Lycium_ruthenicum_ASM4143038v1.fa.gz"
        }
        Cynodon_dactylon {
            fasta = "${params.fasta_base_path}/Cynodon_dactylon_ASM4686236v1.fa.gz"
        }
    }
}

// =========================================================================
// 执行器全局资源和队列配置（结合服务器 128 核 / 503GB 内存，保留安全余量）
// =========================================================================
executor {
    name       = 'local'
    cpus       = 48             // 降低资源限制，避免多用户竞争导致线程耗尽
    memory     = '200 GB'       // 降低资源限制，避免多用户竞争
    queueSize  = 10             // 减少并发任务数，降低线程压力
}

process {
    executor = 'local'

    // 重点：Unicycler & SPAdes 内存限制优化
    withName: 'UNICYCLER' {
        memory   = '64 GB'
        cpus     = 16
        time     = '96.h'
        maxForks = 1            // 降低并发数，避免资源竞争
        ext.args = "--no_rotate --kmers 27,53,71,99,119,127 --spades_options '-m 65536'"
    }

    withName: 'BWA_INDEX' {
        memory   = '64 GB'
        cpus     = 16
        time     = '4.h'
    }

    withName: 'BWA_MEM' {
        memory   = '64 GB'
        cpus     = 16
        time     = '24.h'
    }

    withName: 'SAMTOOLS_SORT' {
        memory   = '32 GB'
        cpus     = 8
        time     = '12.h'
    }

    withName: 'PICARD_MARKDUPLICATES' {
        memory   = '32 GB'
        cpus     = 8
        time     = '12.h'
    }

    withName: 'CIRCLE_MAP_REALIGN' {
        memory   = '64 GB'
        cpus     = 16
        time     = '48.h'
    }

    withName: 'CIRCLE_MAP_REPEATS' {
        memory   = '64 GB'
        cpus     = 16
        time     = '48.h'
    }

    withName: 'CIRCLE_FINDER' {
        memory   = '32 GB'
        cpus     = 8
        time     = '24.h'
    }

    withName: 'CIRC_EXPLORER2_PARSE' {
        memory   = '32 GB'
        cpus     = 8
        time     = '24.h'
    }

    withName: 'FASTQC' {
        memory   = '8 GB'
        cpus     = 4
        time     = '4.h'
    }

    withName: 'TRIMGALORE' {
        memory   = '16 GB'
        cpus     = 8
        time     = '8.h'
    }

    withName: 'SAMTOOLS_INDEX' {
        memory   = '16 GB'
        cpus     = 4
        time     = '4.h'
    }

    withName: 'SAMTOOLS_STATS' {
        memory   = '16 GB'
        cpus     = 4
        time     = '4.h'
    }

    withName: 'MULTIQC' {
        memory   = '32 GB'
        cpus     = 8
        time     = '8.h'
    }
}

// 容器、引擎与环境参数配置
singularity {
    enabled = false
}

docker {
    enabled      = true
    fixOwnership = true
}

conda {
    enabled = false
}

// 输出报告设置
trace {
    enabled   = true
    overwrite = true
}

report {
    enabled   = true
    overwrite = true
}

timeline {
    enabled   = true
    overwrite = true
}


nextflow_process {

    name "Test Process CRESIL_TRIM"
    script "../main.nf"
    process "CRESIL_TRIM"

    tag "modules"
    tag "modules_nfcore"
    tag "cresil"
    tag "cresil/trim"

    test("test-trim") {

        when {
            process {
                """
                input[0] = [ [ id:'test' ], // meta
                             file("\${projectDir}/modules/cresil/testdata/exp_reads.fastq", checkIfExists: true) ]
                input[1] = [ [ id:'ref' ], // meta2
                             file("\${projectDir}/modules/cresil/testdata/ref.mmi", checkIfExists: true) ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }

    }

    test("test-trim - stub") {

        options "-stub"

        when {
            process {
                """
                input[0] = [ [ id:'test' ], // meta
                             file("\${projectDir}/modules/cresil/testdata/exp_reads.fastq", checkIfExists: true) ]
                input[1] = [ [ id:'ref' ], // meta2
                             file("\${projectDir}/modules/cresil/testdata/ref.mmi", checkIfExists: true) ]
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }

    }

}
